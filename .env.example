# AI Voice TTS - Environment Configuration

# Default TTS Settings
DEFAULT_LANGUAGE=en
DEFAULT_SPEAKER=male

# TTS Model Configuration
# Default: tts_models/multilingual/multi-dataset/xtts_v2 (~2GB, supports 16+ languages)
# For CI/testing with smaller models:
#   - tts_models/en/ljspeech/glow-tts (~100MB, English only, fast)
#   - tts_models/en/ljspeech/tacotron2-DDC (~200MB, English only)
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Optional vocoder (only needed for non-end-to-end models like tacotron2)
# Example: vocoder_models/en/ljspeech/hifigan_v2
# Leave empty for end-to-end models like XTTS v2 or glow-tts
TTS_VOCODER=

# CORS Configuration
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Server Ports
TTS_PORT=9876
WEB_PORT=8080

# GPU Configuration (only for GPU mode)
CUDA_VISIBLE_DEVICES=0
