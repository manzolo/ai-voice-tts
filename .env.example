# AI Voice TTS - Environment Configuration

# Default TTS Settings
DEFAULT_LANGUAGE=en
DEFAULT_SPEAKER=male

# CORS Configuration
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Server Ports
TTS_PORT=9876
WEB_PORT=8080

# GPU Configuration (only for GPU mode)
CUDA_VISIBLE_DEVICES=0
